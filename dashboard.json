{
  "dashboard": {
    "id": null,
    "title": "BuildAgent Monitoring",
    "tags": ["buildagent"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Agent Status",
        "type": "stat",
        "targets": [
          {
            "expr": "buildagent_status",
            "legendFormat": "Status"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Active Sessions",
        "type": "stat",
        "targets": [
          {
            "expr": "buildagent_active_sessions",
            "legendFormat": "Sessions"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Actions Per Second",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(buildagent_actions_total[1m])",
            "legendFormat": "Actions/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Task Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "buildagent_task_success_rate",
            "legendFormat": "Success Rate"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 4}
      },
      {
        "id": 5,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(buildagent_errors_total[5m])",
            "legendFormat": "Errors/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 4}
      },
      {
        "id": 6,
        "title": "Response Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(buildagent_response_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "10s"
  }
}
